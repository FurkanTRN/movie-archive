{
    "name": "movie-archive",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "npm run dev:client",
        "dev:client": "vite",
        "dev:server": "tsx watch server/src/index.ts",
        "dev:full": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "start": "vite",
        "start:server": "node dist-server/src/index.js",
        "build": "npm run build:client && npm run build:server",
        "build:client": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
        "build:server": "tsc -p tsconfig.server.json",
        "backup:create": "tsx server/src/scripts/backup-sqlite.ts",
        "db:bootstrap": "tsx server/src/scripts/bootstrap-db.ts",
        "admin:create": "tsx server/src/scripts/create-admin.ts",
        "preview": "vite preview"
    },
    "dependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@types/cors": "^2.8.19",
        "@types/express-session": "^1.18.2",
        "@untitledui/file-icons": "^0.0.9",
        "@untitledui/icons": "^0.0.21",
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "input-otp": "^1.4.2",
        "memorystore": "^1.6.7",
        "motion": "^12.38.0",
        "qr-code-styling": "^1.9.2",
        "react": "^19.2.4",
        "react-aria": "^3.47.0",
        "react-aria-components": "^1.16.0",
        "react-dom": "^19.2.4",
        "react-hotkeys-hook": "^5.2.4",
        "react-router": "^7.13.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tailwindcss-animate": "^1.0.7",
        "tailwindcss-react-aria-components": "^2.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "^5.0.6",
        "@types/node": "^24.10.9",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "concurrently": "^9.2.1",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^8.0.1"
    }
}
