SESSION_MAX_AGE_MS=604800000
TRUST_PROXY=false
COOKIE_SECURE_AUTO=true
TMDB_API_KEY=your-tmdb-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
