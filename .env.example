# Copy this file to `.env`.
# Change the active values below for a normal setup.
# Uncomment advanced overrides only if you need to customize the default behavior.

# Required: use a long random secret, especially in production.
SESSION_SECRET=change-this-to-a-long-random-secret

# Required: TMDb API key used for movie search and metadata.
TMDB_API_KEY=your-tmdb-key

# Default admin account created on first startup when no users exist yet.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Advanced: app runtime defaults.
# NODE_ENV defaults to `development` locally and is forced to `production` by Docker Compose.
# NODE_ENV=development
# PORT=3001
# LOG_LEVEL=debug

# Advanced: same-origin production does not need this.
# Only set APP_BASE_URL when frontend and backend run on different origins in local dev.
# APP_BASE_URL=http://localhost:5173

# Advanced: local data and backup locations.
# SQLITE_DB_PATH=./data/movie-archive.db
# BACKUP_DIR=./backups

# Advanced: only uncomment when running behind a reverse proxy.
# TRUST_PROXY=true

# Advanced: local frontend override.
# Leave unset in production because the app is served from the same origin.
# VITE_API_BASE_URL=http://localhost:3001
